+static qboolean SWimp_InitGraphics( qboolean fullscreen )
+{
+    srandom(getpid());
+
+    // let the sound and input subsystems know about the new window
+    ri.Vid_NewWindow (vid.width, vid.height);
+    is_fullscreen = fullscreen;
+
+    vid.rowbytes = (vid.width + 63) & ~63;
+    vid.buffer = VIRT(VID2);
+
+    int w_width = vid.width;
+    int w_height = vid.height;
+
+    if (fullscreen) {
+        if (w_height < 480) {
+            w_width *= 2;
+            w_height *= 2;
+            init_dma_cmd_with_upscale(VIRT(DMA_CMD_BUF1), PHYS(VID1));
+            dma_cmd_count = init_dma_cmd_with_upscale(VIRT(DMA_CMD_BUF2), PHYS(VID2));
+        } else {
+            init_dma_cmd_no_upscale(VIRT(DMA_CMD_BUF1), PHYS(VID1));
+            dma_cmd_count = init_dma_cmd_no_upscale(VIRT(DMA_CMD_BUF2), PHYS(VID2));
+        }
+        init_dma_cmd_load_palette();
+    } else {
+        dma_cmd_count = 0;
+    }
+
+    unsigned flags = SDL_SWSURFACE | SDL_ANYFORMAT;
+    if (fullscreen) flags |= SDL_FULLSCREEN;
+    surface = SDL_SetVideoMode(w_width, w_height, 16, flags);
+
+    if (surface == NULL) {
+        Sys_Error("(SOFTSDL) SDL_SetVideoMode failed: %s\n", SDL_GetError());
+        return false;
+    }
+    if (surface->format->BitsPerPixel != 16) {
+        Sys_Error("(SOFTSDL) pixelformat must be 16-bit");
+        return false;
+    }
+
+    SDL_WM_SetCaption("Quake II", "Quake II");
+
+    window_active = true;
+
+    return true;
+}
+
+#ifdef USE_NO_DMA
+static unsigned mixrgb(unsigned a, unsigned b) {
+#if 1
+    unsigned mask = 1 | (1<<5) | (1<<11) | (1<<16) | (1<<21) | (1<<27);
+    //return (a & mask) + ((a & ~mask) >> 1) + ((b & ~mask) >> 1);
+    return (a & b) + ((((a ^ b) & ~mask) >> 1)
+#else
+    // Custom MIXRGB instruction implemented in endeavour2/rtl/src/main/scala/endeavour2/CustomInstructions.scala
+    unsigned result;
+    asm(".insn r 0x0b, 0, 0, %0, %1, %2" : "=r" (result) : "r" (a), "r" (b));
+    return result;
+#endif
+}
+
+static void expand_line(const uint8_t* src, uint16_t* dst) {
+    const unsigned short* palette = VIRT(PALETTE);
+    unsigned prev = palette[src[0]*2];
+    for (unsigned x = 0; x < vid.width; ++x) {
+        unsigned next = palette[src[x]*2];
+        dst[0] = mixrgb(prev, next);
+        dst[1] = next;
+        dst += 2;
+        prev = next;
+    }
+}
+
+static void avg_line(const unsigned* src1, const unsigned* src2, unsigned* dst) {
+    for (unsigned i = 0; i < vid.width; ++i) {
+        dst[i] = mixrgb(src1[i], src2[i]);
+    }
+}
+#endif
+
+extern int tt_before_swimp_endframe;
+void SWimp_EndFrame (void)
+{
+tt_before_swimp_endframe = Sys_Milliseconds();
+    uint8_t* src = (uint8_t*)vid.buffer;
+    if (!is_fullscreen) {
+        SDL_LockSurface(surface);
+        unsigned short* dst = (uint16_t *)surface->pixels;
+        unsigned short* palette = VIRT(PALETTE);
+        unsigned pitch = surface->pitch;
+        for (unsigned y = 0; y < vid.height; ++y) {
+            for (unsigned x = 0; x < vid.width; ++x) {
+                dst[x] = palette[src[x]*2];
+            }
+            dst += pitch/2;
+            src += vid.rowbytes;
+        }
+        SDL_UnlockSurface(surface);
+        SDL_Flip(surface);
+    } else {
+#ifndef USE_NO_DMA
+        display_dma(e2fd, PHYS(DMA_CMD_PALETTE), 2, /*sync=*/1);
+        if (vid.buffer == VIRT(VID1)) {
+          display_dma(e2fd, PHYS(DMA_CMD_BUF1), dma_cmd_count, /*sync=*/0);
+          vid.buffer = VIRT(VID2);
+        } else {
+          display_dma(e2fd, PHYS(DMA_CMD_BUF2), dma_cmd_count, /*sync=*/0);
+          vid.buffer = VIRT(VID1);
+        }
+#else
+        if (surface->w == vid.width * 2 && surface->h == vid.height * 2) {
+#if 1  // upscale with linear approximation
+            unsigned line_pixels = GRAPHIC_LINE_SIZE / 2;
+            unsigned short* dst = VIRT(FB_LINE(0));
+            expand_line(src, dst);
+            for (unsigned y = 1; y < vid.height; ++y) {
+                dst += line_pixels * 2;
+                src += vid.rowbytes;
+                expand_line(src, dst);
+                avg_line((unsigned*)dst, (unsigned*)(dst - line_pixels * 2), (unsigned*)(dst - line_pixels));
+            }
+            dst += line_pixels;
+            expand_line(src, dst);
+#else  // upscale with nearest pixel
+            const unsigned* palette = VIRT(PALETTE);
+            for (unsigned y = 0; y < vid.height; ++y) {
+                unsigned* dst1 = VIRT(FB_LINE(y*2));
+                unsigned* dst2 = VIRT(FB_LINE(y*2+1));
+                for (unsigned x = 0; x < vid.width; ++x) {
+                    dst1[x] = dst2[x] = palette[src[x]];
+                }
+                src += vid.rowbytes;
+            }
+#endif
+        } else {
+            const unsigned short* palette = VIRT(PALETTE);
+            for (unsigned y = 0; y < vid.height; ++y) {
+                unsigned short* dst = VIRT(FB_LINE(y));
+                for (unsigned x = 0; x < vid.width; ++x) {
+                    dst[x] = palette[src[x]*2];
+                }
+                src += vid.rowbytes;
+            }
+        }
+#endif
+    }
+}

diff --git a/src/linux/snd_e2.c b/src/linux/snd_e2.c
new file mode 100644
index 0000000..e93f7c9
--- /dev/null
+++ b/src/linux/snd_e2.c
@@ -0,0 +1,82 @@
+#include <fcntl.h>
+#include <unistd.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+
+#include "../client/client.h"
+#include "../client/snd_loc.h"
+
+static int snd_inited;
+static void *buffer;
+static int fd = -1;
+
+qboolean SNDDMA_Init(void)
+{
+    int errorcode;
+    int frag_spec;
+
+    if(snd_inited)
+        return 1;
+
+    fd = open("/dev/audio", O_RDWR);
+
+    dma.samplebits = 16;
+
+    int khz =(Cvar_Get("s_khz", "22", CVAR_ARCHIVE))->value;
+
+    if (khz == 44)
+        dma.speed = 44100;
+    else if (khz == 22)
+        dma.speed = 22050;
+    else
+        dma.speed = 11025;
+    ioctl(fd, 0xaa0, dma.speed);
+
+    dma.channels = 2;
+    dma.samples = 16384;
+    dma.samplepos = 0;
+    dma.submission_chunk = 1;
+    dma.buffer = mmap(0, dma.samples * 2,  PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);
+    if (!dma.buffer) {
+        Com_Printf ("Sound mmap failed\n");
+        return 0;
+    }
+
+    snd_inited=1;
+
+    return 1;
+}
+
+int SNDDMA_GetDMAPos(void)
+{
+    unsigned v;
+    if(!snd_inited) {
+        Com_Printf ("Sound not inizialized\n");
+        return 0;
+    }
+    if (ioctl(fd, 0xaa1, &v) < 0) {
+        Com_Printf ("GetDMAPos failed\n");
+        return 0;
+    }
+    dma.samplepos = v / 2;
+    return dma.samplepos;
+}
+
+void SNDDMA_Shutdown(void)
+{
+    if(!snd_inited) {
+        Com_Printf ("Sound not inizialized\n");
+        return;
+    }
+    munmap(dma.buffer, dma.samples * 2);
+    close(fd);
+    snd_inited=0;
+}

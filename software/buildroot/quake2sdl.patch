@@ -0,0 +1,21 @@
+# Target System Settings
+set(CMAKE_SYSTEM_NAME Linux)
+set(CMAKE_SYSTEM_PROCESSOR riscv32)
+
+# Toolchain Paths
+set(TOOLCHAIN_ROOT "$ENV{HOME}/endeavour2-ext/buildroot-2025.02/output/host")
+set(CMAKE_C_COMPILER "${TOOLCHAIN_ROOT}/bin/riscv32-unknown-linux-gnu-gcc")
+set(CMAKE_CXX_COMPILER "${TOOLCHAIN_ROOT}/bin/riscv32-unknown-linux-gnu-g++")
+set(CMAKE_FIND_ROOT_PATH "$ENV{HOME}/endeavour2-ext/buildroot-2025.02/output/staging")
+
+# Optimization and RISC-V specific flags
+set(RISCV_FLAGS "-march=rv32gc_zba -mabi=ilp32d -Ofast -I$ENV{HOME}/endeavour2/software/include")
+set(CMAKE_C_FLAGS "${RISCV_FLAGS}" CACHE STRING "" FORCE)
+set(CMAKE_CXX_FLAGS "${RISCV_FLAGS}" CACHE STRING "" FORCE)
+
+# Force search in staging directory
+set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
+set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
+set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
+set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
+
